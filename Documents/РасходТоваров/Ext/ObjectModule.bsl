// Модуль объекта: Document.РасходТоваров

Процедура ОбработкаПроведения(Отказ, РежимПроведения)
	
	// Очистка движений при перепроведении
	Если РежимПроведения.РежимПроведения = РежимПроведенияДокумента.Перепроведение Тогда
		Движения.ОстаткиТоваров.Очистить();
	КонецЕсли;
	
	// Формирование движений по регистру "ОстаткиТоваров"
	ДвижениеОстатки = Движения.ОстаткиТоваров;
	ДвижениеОстатки.Записывать = Истина;
	
	Для Каждого СтрокаТоваров Из Объект.Товары Цикл
		
		Если СтрокаТоваров.Номенклатура = Неопределено Тогда
			Продолжить;
		КонецЕсли;
		
		Запись = ДвижениеОстатки.Добавить();
		Запись.ВидДвижения = ВидДвиженияНакопления.Расход;
		Запись.Период = Объект.Дата;
		Запись.Регистратор = Объект.Ссылка;
		Запись.Номенклатура = СтрокаТоваров.Номенклатура;
		Запись.Характеристика = СтрокаТоваров.Характеристика;
		Запись.Количество = СтрокаТоваров.Количество;
		
	КонецЦикла;
	
КонецПроцедуры
